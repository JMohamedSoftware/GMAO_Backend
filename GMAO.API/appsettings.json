{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=GmaoDB;Username=postgres;Password=123"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_VERY_LONG_SECRET_KEY_AT_LEAST_32_CHARACTERS",
    "Issuer": "GMAO.API",
    "Audience": "GMAO.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "FileStorage": {
    "BasePath": "uploads",
    "MaxFileSizeMB": 20,
    "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".docx", ".xlsx", ".mp4" ]
  },
  "AppSettings": {
    "AppName": "GMAO - Gestion de Maintenance Agroalimentaire",
    "Version": "1.0.0"
  }
}

